const CACHE_NAME = "lumiera-cache-v2";
const BASE_URL = self.registration.scope;

const urlsToCache = [
  `${BASE_URL}`,
  `${BASE_URL}index.html`,
  `${BASE_URL}manifest.json`,
  // Ikon utama
  `${BASE_URL}icons/icon-192x192-A.png`,
  `${BASE_URL}icons/icon-512x512-B.png`,
  // Screenshots
  `${BASE_URL}icons/screenshot1.png`,
  `${BASE_URL}icons/screenshot2.png`,
  // Shortcut icons (tambahan)
  `${BASE_URL}icons/shortcut-scan.png`,
  `${BASE_URL}icons/shortcut-makeup.png`,
  `${BASE_URL}icons/shortcut-tracker.png`,
];

self.addEventListener("install", event => {
  self.skipWaiting();
  event.waitUntil(
    caches.open(CACHE_NAME)
      .then(cache => {
        console.log("Caching app shell...");
        // Gunakan individual add agar 1 gagal tidak block semua
        return Promise.allSettled(
          urlsToCache.map(url => cache.add(url).catch(err => console.warn("Skip cache:", url, err)))
        );
      })
  );
});

self.addEventListener("activate", event => {
  event.waitUntil(
    (async () => {
      const keys = await caches.keys();
      await Promise.all(
        keys.map(key => {
          if (key !== CACHE_NAME) {
            console.log("Menghapus cache lama:", key);
            return caches.delete(key);
          }
        })
      );
      await self.clients.claim();
    })()
  );
});

self.addEventListener("fetch", event => {
  const request = event.request;
  const url = new URL(request.url);

  if (request.method !== "GET" || url.protocol.startsWith("chrome-extension")) return;

  event.respondWith(
    caches.match(request).then(response => {
      return response || fetch(request).then(networkResponse => {
        // Cache dinamis untuk aset baru
        if (networkResponse.ok) {
          const responseClone = networkResponse.clone();
          caches.open(CACHE_NAME).then(cache => cache.put(request, responseClone));
        }
        return networkResponse;
      });
    }).catch(() => {
      if (request.mode === "navigate") {
        return caches.match(`${BASE_URL}index.html`);
      }
    })
  );
});
